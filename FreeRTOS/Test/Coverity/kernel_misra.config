// MISRA C-2012 Rules

{
    version : "2.0",
    standard : "c2012",
    title: "Coverity MISRA Configuration",
    deviations : [
        {
            deviation: "Rule 3.1",
            reason: "We post HTTP links in code comments which contain // inside comments blocks."
        },
        {
            deviation: "Rule 11.3",
            reason: "Allow kernel object static allocation for StaticEventGroup_t, StaticQueue_t, StaticStreamBuffer_t, StaticTimer_t and StaticTask_t."
        },
        {
            deviation: "Rule 11.5",
            reason: "Allow casts from `void *`. List owner, pvOwner, is stored as `void *` and are cast to various types for use in functions."
        },
        {
            deviation: "Rule 5.8",
            reason: "MPU feature makes use of define the function name with marco for privileged and un-privileged APIs."
        },
        {
            deviation: "Rule 14.4",
            reason: "do while( 0 ) patter is used in macro to prevent extra semi-colon."
        },

        // Disable the following advisory rules.
